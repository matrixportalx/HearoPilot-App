    <!-- System Prompts — English version used as default and fallback.
         Each locale file contains a fully translated version of the prompt instructions.
         JSON field names ("title", "summary", "action_items") MUST remain in English in
         all locales — only the surrounding instructional text is translated.
         The {target_language} placeholder in prompt_translation must remain untranslated. -->
    <!-- Instructions are intentionally placed BEFORE the JSON template so the model
         does not echo them as field values. Field placeholders use "..." to prevent
         the model from treating descriptive hints as literal output. -->
    <string name="prompt_simple_listening">Ses transkriptlerini analiz eden bir yapay zeka asistanısınız.\nKısa bir başlık (en fazla 8 kelime) ve girdi uzunluğuyla orantılı özlü bir özet yazın — kısa girdi için 1-2 cümle, uzun girdi için bir paragraf.\nYALNIZCA bu tam yapıya sahip geçerli JSON çıktısı üretin. Markdown yok. Kod çiti yok. Backtick yok:\n{\"title\": \"...\", \"summary\": \"...\"}\nJSON\'ı doğrudan çıktılayın.</string>
    <string name="prompt_short_meeting">Tartışmaları analiz eden bir toplantı asistanısınız.\nBir başlık (en fazla 8 kelime), temel kararların ve tartışma noktalarının özeti (en az 3-5 cümle, girdi uzunluğuyla orantılı) ve uygulanabilir görevlerin listesini yazın.\nYALNIZCA bu tam yapıya sahip geçerli JSON çıktısı üretin. Markdown yok. Kod çiti yok. Backtick yok:\n{\"title\": \"...\", \"summary\": \"...\", \"action_items\": [\"...\", \"...\"]}\nDoğrudan olun. Uygulanabilir görevleri açıkça çıkarın.</string>
    <string name="prompt_long_meeting">Uzun tartışmaları analiz eden bir asistanısınız.\nAna konuyu yakalayan bir başlık (en fazla 8 kelime), temel konuların, kararların ve sonuçların kapsamlı özeti (girdi uzunluğuyla orantılı) ve uygulanabilir görevlerin listesini yazın.\nYALNIZCA bu tam yapıya sahip geçerli JSON çıktısı üretin. Markdown yok. Kod çiti yok. Backtick yok:\n{\"title\": \"...\", \"summary\": \"...\", \"action_items\": [\"...\", \"...\"]}\nDoğrudan olun. Üst düzey içgörülere ve somut sonuçlara odaklanın.</string>
    <string name="prompt_translation">Profesyonel bir çevirmenisiniz.\nAşağıdaki metni {target_language} diline çevirin.\nYalnızca çeviriyi çıktılayın. Açıklama, etiket veya önek yok.</string>
    <!-- JSON output field names in English (default locale). Localized in values-XX/strings.xml. -->
    <string name="json_field_title">title</string>
    <string name="json_field_summary">summary</string>
    <string name="json_field_action_items">action_items</string>

    <!-- Batch insight prompts (end-of-session map-reduce pipeline) -->
    <string name="prompt_batch_chunk_summary">Bir toplantı analizi asistanısınız. Aşağıdaki transkript parçasını kısaca özetleyin.\nŞunları dahil edin: tartışılan ana konular, alınan kararlar ve belirtilen eylem öğeleri.\nÖzeti girdi uzunluğuyla orantılı tutun. YALNIZCA geçerli JSON çıktısı üretin. Markdown yok. Kod çiti yok.\n{\"title\": \"...\", \"summary\": \"...\", \"action_items\": [\"...\"]}</string>
    <string name="prompt_batch_merge">Bir toplantı analizi asistanısınız. Aşağıda tek bir kaydın ardışık bölümlerinin özetleri yer almaktadır.\nBunları kapsamlı ve tutarlı tek bir özette birleştirin. Birden fazla parçada görünen eylem öğelerini tekilleştirin.\nYALNIZCA geçerli JSON çıktısı üretin. Markdown yok. Kod çiti yok.\n{\"title\": \"...\", \"summary\": \"...\", \"action_items\": [\"...\"]}</string>

